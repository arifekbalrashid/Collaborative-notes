# ─── Local Development ───────────────────────────────────────────────
# Copy this file to .env and fill in the values

# JWT secret (any random string)
SECRET_KEY=your-secret-key-here

# MySQL connection string
# For local MySQL:
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/collaborative_notes

# For Aiven MySQL (paste from Aiven Console → Overview → Connection information):
# DATABASE_URL=mysql://avnadmin:PASSWORD@mysql-xxx.aivencloud.com:12345/defaultdb

# Path to Aiven CA certificate (download from Aiven Console → Overview → CA Certificate)
# Leave empty for local MySQL without SSL
MYSQL_SSL_CA=

# CORS origins (comma-separated, or * for all)
ALLOWED_ORIGINS=*

# Server port
PORT=8000
